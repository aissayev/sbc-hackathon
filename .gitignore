# AWS/S3 creds in ~/.aws — those are outside the repo, but defensive
# ignores here catch anyone copying creds into the project tree.
.aws/
.s3cfg
.doctlcfg
*.pem
*.key
*credentials*
*.token
secrets/
.do/local.yaml
*.db
*.db-journal
.DS_Store
