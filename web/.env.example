# ─── Required ─────────────────────────────────────────────────────────────

# Where the Hono backend lives. The Next.js server proxies /api/*, /openapi.json
# to this URL via next.config.mjs rewrites — set it to your ngrok HTTPS URL
# in dev, and to the droplet's local backend URL in prod (or another ngrok).
# Browser never talks to this directly; only the Next server does.
BACKEND_URL=https://YOUR-NGROK-SUBDOMAIN.ngrok-free.app

# Public origin of THIS site. Feeds Schema.org JSON-LD canonicals, sitemap.xml,
# OpenGraph tags, llms.txt URLs. Include https:// and no trailing slash.
NEXT_PUBLIC_SITE_URL=https://happycake.flowleads.dev


# ─── Optional ─────────────────────────────────────────────────────────────

# Only needed if you want client-side fallbacks to call the backend directly
# (we don't — all client fetches go through /api/* and are server-proxied).
# Leave unset in prod.
# NEXT_PUBLIC_BACKEND_URL=https://YOUR-NGROK-SUBDOMAIN.ngrok-free.app

# Server-only shared secret for Next.js SSR → Hono /api/admin/* reads. Set the
# SAME value in the backend's .env.local under WEB_BACKEND_SECRET. Without it,
# the SSR reads ride open mode — fine for hackathon, lock down for production.
# WEB_BACKEND_SECRET=
