# Backend API base. The Next.js server-side fetcher reads BACKEND_URL first,
# falls back to NEXT_PUBLIC_BACKEND_URL, then to localhost:3000.
BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# Public origin used in JSON-LD, sitemap, OG tags.
NEXT_PUBLIC_SITE_URL=https://happycake.us

# Telegram bot used for the owner Mini App.
NEXT_PUBLIC_TELEGRAM_BOT=happycake_owner_bot
