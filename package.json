    "evidence": "bun src/scripts/evidence.ts",
    "e2e": "bun src/scripts/e2e-suite.ts",
    "self-eval": "bun src/scripts/self-eval.ts",
    "marketing:digest": "bun src/scripts/marketing-digest.ts",
    "wa:followup": "bun src/scripts/wa-followup.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "hono": "^4.6.13",
    "zod": "^3.24.1"
