# Happy Cake US — environment variables.
# Copy to .env.local and fill in. NEVER commit secrets.

# === Sandbox MCP (Steppe Business Club) ===
# Issued per team. Replace with your real token in .env.local.
SBC_MCP_URL=https://www.steppebusinessclub.com/api/mcp
SBC_TEAM_TOKEN=sbc_team_REPLACE_WITH_YOURS

# === Server ===
PORT=3000
PUBLIC_URL=https://your-tunnel.ngrok-free.app
NODE_ENV=development

# === Claude Code ===
# Path to claude CLI; usually auto-resolved from PATH.
CLAUDE_BIN=claude
# Pin Opus 4.7 per hackathon constraint.
CLAUDE_MODEL=claude-opus-4-7
# Max budget per agent invocation (USD), safety cap.
CLAUDE_MAX_BUDGET_USD=2.50

# === Telegram bots — one per role ===
# Each bot gets its own token from BotFather.
TG_OWNER_BOT_TOKEN=
# Multi-owner whitelist — comma-separated Telegram chat ids that act as
# "owners" (can approve/reject drafts, ack escalations, see daily reports).
# Add ids as needed:  TG_OWNER_CHAT_IDS=12345,67890,11122
# Empty = OPEN MODE during hackathon (any chat may interact). Production
# deploys MUST populate the whitelist; the server logs a clear warning when
# running open. The legacy singular TG_OWNER_CHAT_ID is still read as a
# fallback so existing demos keep working.
TG_OWNER_CHAT_IDS=
TG_OWNER_CHAT_ID=
TG_CONCIERGE_BOT_TOKEN=
TG_KITCHEN_BOT_TOKEN=
TG_MARKETING_BOT_TOKEN=
# Owner event-log verbosity in TG: verbose | normal | quiet | off (default normal).
# normal = inbound + outbound + errors. quiet = errors only. verbose = +system events.
TG_OWNER_LOG_LEVEL=normal

# === OpenAI (voice-message transcription via Whisper) ===
# Optional. When set, Telegram voice notes are transcribed via OpenAI Whisper
# (multilingual — Russian, English, Kazakh auto-detected) and the transcript
# is fed into the agent as if the owner had typed it. When unset, voice notes
# get a polite "type your message instead" reply.
# Cost: ~$0.006/min ($0.36/hr). Owner volume is < 10 min/day → effectively free.
OPENAI_API_KEY=
# Optional override; defaults to whisper-1 (supports verbose_json for language
# detection). Use 'gpt-4o-mini-transcribe' for ~50% lower cost (text-only).
OPENAI_STT_MODEL=whisper-1

# === WhatsApp Cloud API ===
WA_PHONE_NUMBER_ID=
WA_TOKEN=
WA_VERIFY_TOKEN=happycake_verify_2026
WA_BUSINESS_ACCOUNT_ID=
# Meta App Secret — required for HMAC signature verification on inbound
# webhooks in production. When unset, sandbox-injected unsigned bodies are
# accepted (dev path) with a warning.
WA_APP_SECRET=
# Outbound mode: 'real' | 'sandbox' | 'both' (default).
# 'both' = call Meta Cloud API + sandbox MCP `whatsapp_send` in parallel.
WA_OUTBOUND_MODE=both

# === Instagram Graph API (IG-direct) ===
IG_USER_ID=
IG_TOKEN=
IG_TOKEN_EXPIRES_AT=
IG_APP_ID=
IG_APP_SECRET=
IG_VERIFY_TOKEN=happycake_verify_2026
IG_OUTBOUND_MODE=both

# === Storage ===
DB_PATH=.data/happycake.db
PHOTO_DIR=data/photos

# === DigitalOcean Spaces — customer chat + custom-cake photo uploads ===
#
# Used by /api/uploads (the chat widget, help-widget, and custom-cake funnel
# all POST attachments here). Brand/product/hero/social images do NOT go
# through this — they live on the hackathon CDN and are read-only via
# NEXT_PUBLIC_CDN_BASE in the website.
#
# Behaviour gate:
#   SPACES_KEY + SPACES_SECRET set  → uploads land in Spaces, response carries
#                                     a public CDN URL (CDN-cached, immutable)
#   either unset                    → fall back to backend local disk at
#                                     .data/uploads/, served via the backend's
#                                     /uploads/* route. Safe for dev + the
#                                     hackathon demo (single backend instance,
#                                     no redeploys mid-demo). NOT safe for
#                                     real prod — files vanish on container
#                                     replacement and aren't shareable across
#                                     multiple backend instances.
#
# Setup (production):
#   1. doctl spaces create happycake-uploads --region nyc3
#   2. Generate S3-style key + secret at
#        https://cloud.digitalocean.com/account/api/spaces
#      Scope it to the single bucket; never reuse a global key.
#   3. Put the values below; restart the backend.
SPACES_REGION=nyc3
SPACES_BUCKET=happycake-uploads
# Optional — derive from region/bucket if unset:
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_CDN_BASE=https://happycake-uploads.nyc3.cdn.digitaloceanspaces.com
SPACES_KEY=
SPACES_SECRET=

# === Feature flags ===
AGENT_ENABLED=true
WORLD_SCENARIO_ENABLED=false

# === Catalog sync (sandbox MCP → local SQLite mirror) ===
# Background pull cadence in ms. 0 disables periodic sync (still runs once at startup).
CATALOG_SYNC_INTERVAL_MS=300000
# Shared secret required to POST /api/catalog/sync. Unset = endpoint disabled.
CATALOG_SYNC_SECRET=

# === Owner cockpit — content + analytics schedulers ===
# Content scheduler: publishes drafts whose `scheduled_for` has passed and
# expires stale (>72h untouched) drafts. Default 5 min; 0 disables.
CONTENT_SCHEDULER_INTERVAL_MS=300000
# Snapshot scheduler: rebuilds the digital-presence snapshot for /stats and
# pushes any NEW high-severity alerts to the owner. Default 1 hour; 0 disables.
SNAPSHOT_INTERVAL_MS=3600000

# === Admin auth (/api/admin/*) ===
# Two trust paths gate /api/admin/* — set either or both:
#   1. WEB_BACKEND_SECRET — shared secret for Next.js SSR → Hono server-to-server
#      reads. Set the SAME value in web/.env.local. Random ≥ 32 bytes recommended.
#   2. TG_OWNER_BOT_TOKEN (above) — when set, Mini App browsers launched from
#      the bot's menu button authenticate via signed Telegram.WebApp.initData.
# With NEITHER set, /api/admin/* runs in OPEN MODE — fine for the hackathon
# build window, but the boot log emits a clear warning so it can't ship that
# way by accident.
WEB_BACKEND_SECRET=
